# ─── Global ───────────────────────────────────────────────────
NODE_ENV=development
# Log full request/response JSON bodies (API). Default: on in dev, off when NODE_ENV=production.
LOG_HTTP_BODIES=true

# ─── Web (apps/web) ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── API (apps/api — NestJS) ──────────────────────────────────
API_PORT=8080
# Railway injects PORT — API uses API_PORT or PORT automatically
API_HOST=0.0.0.0
CLIP_CREDIT_COST=1
# OAuth redirect target after YouTube connect (production: https://autoclipr.com)
WEB_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,https://autoclipr.ai,https://autoclipr.io,https://autoclipr.com

# Supabase (server-side) — use service_role key from Settings → API (NOT the anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings-api-jwt-secret

# Database (direct Postgres — Supabase Dashboard → Settings → Database)
# IMPORTANT: One line only — do NOT prefix with DATABASE_URL= twice.
# If your DB password contains @ or # encode them: @ → %40, # → %23
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# JWT (API-issued tokens for service-to-service; Supabase JWT validated via JWKS)
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# Storage buckets
STORAGE_BUCKET_VIDEOS=videos
STORAGE_BUCKET_CLIPS=clips
STORAGE_BUCKET_EXPORTS=exports
STORAGE_BUCKET_AVATARS=avatars

# Queue (workers) — Redis 6.2+ required (BullMQ). Legacy Windows Redis 5.x will warn.
# Fix: scripts/start-redis.ps1 (Docker) OR scripts/fix-redis-admin.ps1 (Memurai, run as Admin)
REDIS_URL=redis://localhost:6379
QUEUE_CLIP_PROCESSING=clip_processing

# AI providers (workers)
# ── Transcription (required for real captions) — OpenAI Whisper only today
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
WHISPER_MODEL=whisper-1
# Whisper requires paid OpenAI billing (~$5 min). Fallback clips if quota fails:
OPENAI_FALLBACK_ON_QUOTA=true

# ── Hook / viral moment analysis (cheaper with DeepSeek)
# LLM_PROVIDER=openai  OR  deepseek
LLM_PROVIDER=deepseek
# Used when LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
# Used when LLM_PROVIDER=deepseek (~10× cheaper than GPT-4o)
# Get key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional future transcription provider — not wired yet
ASSEMBLYAI_API_KEY=

# Media pipeline (workers)
# Leave WORK_DIR empty to use system temp folder
WORK_DIR=
# Supabase free tier: 50 MB max per uploaded object (52428800). Set 0 to skip client-side check.
STORAGE_MAX_UPLOAD_BYTES=52428800
# Optional download height cap (0 = best available quality, recommended)
YTDLP_MAX_HEIGHT=0
# Optional: reject sources longer than N seconds (0 = no limit)
YTDLP_MAX_DURATION_SECONDS=0
# Windows (WinGet): use full paths if workers can't find binaries on PATH
# YTDLP_PATH=C:\Users\YOUR_USER\AppData\Local\Microsoft\WinGet\Links\yt-dlp.exe
# FFMPEG_PATH=C:\Users\YOUR_USER\AppData\Local\Microsoft\WinGet\Packages\yt-dlp.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe\ffmpeg-N-124716-g054dffd133-win64-gpl\bin\ffmpeg.exe
# FFPROBE_PATH=C:\Users\YOUR_USER\AppData\Local\Microsoft\WinGet\Packages\yt-dlp.FFmpeg_Microsoft.Winget.Source_8wekyb3d8bbwe\ffmpeg-N-124716-g054dffd133-win64-gpl\bin\ffprobe.exe
# Or if `yt-dlp --version` works in a new terminal, these defaults are fine:
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
YTDLP_PATH=yt-dlp
# Cloud/Railway: YouTube may block datacenter IPs. Optional fixes:
# YTDLP_EXTRACTOR_ARGS=youtube:player_client=android,web;player_skip=webpage
# YTDLP_COOKIES_FILE=/path/to/youtube-cookies.txt
# Railway: export cookies.txt from Chrome, then base64 -w0 cookies.txt (Linux) or [Convert]::ToBase64String([IO.File]::ReadAllBytes("cookies.txt")) (PowerShell)
# YTDLP_COOKIES_B64=<base64 of Netscape cookies.txt>

# Stripe (billing — optional)
STRIPE_SECRET_KEY=

# New Relic (optional — observability)
# Get license key: https://one.newrelic.com/admin-portal/api-keys/home
NEW_RELIC_LICENSE_KEY=
NEW_RELIC_APP_NAME=AutoClipr
NEW_RELIC_LOG_LEVEL=info
# API service:
# NEW_RELIC_APP_NAME=AutoClipr API
# Workers service:
# NEW_RELIC_APP_NAME=AutoClipr Workers

# YouTube posting OAuth (required to post clips as YouTube Shorts)
# Create OAuth credentials: https://console.cloud.google.com/apis/credentials
# Enable YouTube Data API v3. Redirect URI:
#   http://localhost:8080/api/v1/platforms/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
API_PUBLIC_URL=http://localhost:8080

STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
